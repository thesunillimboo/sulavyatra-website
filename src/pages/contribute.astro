---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/common/Container.astro";
---

<MainLayout
  title="Become a Contributor | Sulav Yatra"
  description="Share real Nepal travel experiences, stories, photography, videos and local knowledge with Sulav Yatra."
>
  <main>
    <section class="hero">
      <Container>
        <div class="hero-content">
          <span class="eyebrow">Become a Contributor</span>
          <h1>Turn Real Nepal Travel Experiences Into Stories That Matter</h1>
          <p>
            Sulav Yatra is building a trusted travel platform for Nepal through practical guides,
            local stories, cultural insights and authentic experiences.
          </p>
        </div>
      </Container>
    </section>

    <section class="intro-section">
      <Container>
        <div class="intro-card">
          <div class="intro-copy">
            <span class="section-kicker">Why contributors matter</span>
            <h2>The best travel information does not come from one team alone.</h2>
            <p>
              It comes from real travelers, trekkers, photographers, local explorers, guides and
              storytellers who have walked the trails, taken the buses, stayed in the villages,
              joined the festivals and experienced Nepal firsthand.
            </p>
            <p>
              If you have real travel knowledge worth sharing, we would love to hear from you.
            </p>
          </div>

          <div class="intro-note">
            <strong>Real experiences from real people.</strong>
            <span>
              Not overly polished tourism brochures. Not generic AI-generated travel articles.
            </span>
          </div>
        </div>
      </Container>
    </section>

    <section class="mission-section">
      <Container>
        <div class="mission-box">
          <span class="section-kicker">Why this matters</span>
          <h2>Nepal deserves better travel storytelling.</h2>
          <p>
            Sulav Yatra exists to make discovering Nepal easier, more reliable and more meaningful.
            Contributors help us bring more destinations, routes, cultures and local experiences into
            the spotlight.
          </p>
          <p>
            Together, we can help more travelers explore Nepal smarter while supporting local tourism
            and preserving authentic stories.
          </p>
        </div>
      </Container>
    </section>

    <section class="who-section">
      <Container>
        <div class="section-header">
          <span class="section-kicker">Who can contribute?</span>
          <h2>You do not need to be a professional writer.</h2>
          <p>
            If your experience can help someone understand or explore Nepal better, it matters.
          </p>
        </div>

        <div class="people-grid">
          <span>Travelers exploring Nepal</span>
          <span>Trekkers and backpackers</span>
          <span>Road trippers</span>
          <span>Adventure travelers</span>
          <span>Travel photographers</span>
          <span>Travel vloggers</span>
          <span>Local explorers</span>
          <span>Guides and tourism professionals</span>
          <span>Students and young creators</span>
          <span>Community members with local knowledge</span>
        </div>
      </Container>
    </section>

    <section class="share-section">
      <Container>
        <div class="section-header">
          <span class="section-kicker">What you can share</span>
          <h2>Useful, honest and experience-based travel content.</h2>
          <p>
            Your contribution does not need to be perfect from the beginning. What matters most is that
            it is useful, honest and based on real experience.
          </p>
        </div>

        <div class="content-grid">
          <div class="content-card">
            <span>01</span>
            <h3>Travelogues</h3>
            <p>Personal travel stories, journeys, routes and experiences from across Nepal.</p>
          </div>

          <div class="content-card">
            <span>02</span>
            <h3>Destination Guides</h3>
            <p>Helpful guides to places, hidden gems, itineraries and local recommendations.</p>
          </div>

          <div class="content-card">
            <span>03</span>
            <h3>Practical Advice</h3>
            <p>Transportation guides, budget tips, food experiences and travel planning help.</p>
          </div>

          <div class="content-card">
            <span>04</span>
            <h3>Culture & Festivals</h3>
            <p>Stories that help preserve and share Nepal's diverse cultural heritage.</p>
          </div>

          <div class="content-card">
            <span>05</span>
            <h3>Photos & Videos</h3>
            <p>Original photographs, short clips and visual stories from real journeys.</p>
          </div>

          <div class="content-card">
            <span>06</span>
            <h3>Local Tips</h3>
            <p>Small details that help travelers understand places better and travel smarter.</p>
          </div>
        </div>
      </Container>
    </section>

    <section class="rules-section">
      <Container>
        <div class="rules-layout">
          <div class="rules-intro">
            <span class="section-kicker">Our ground rules</span>
            <h2>Trust comes first.</h2>
            <p>
              To maintain trust with our readers, we follow clear contributor standards.
            </p>
          </div>

          <div class="rules-list">
            <div>
              <h3>Real Experiences Only</h3>
              <p>Your story or guide should be based on places you have personally visited or knowledge you genuinely understand.</p>
            </div>

            <div>
              <h3>No Fabricated AI Travel Stories</h3>
              <p>We do not accept fake travel experiences or fully AI-generated destination stories.</p>
            </div>

            <div>
              <h3>Original Media Preferred</h3>
              <p>Photos and videos should be your own whenever possible. If you use someone else's media, permission and proper credit are required.</p>
            </div>

            <div>
              <h3>Honest Recommendations</h3>
              <p>No misleading information, fake reviews or hidden promotions.</p>
            </div>

            <div>
              <h3>Practical Value Matters</h3>
              <p>Your content should help travelers make better decisions, understand a place more clearly or discover something meaningful about Nepal.</p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <section class="benefits-section">
      <Container>
        <div class="section-header">
          <span class="section-kicker">Why contribute?</span>
          <h2>More than a one-time article submission.</h2>
        </div>

        <div class="benefits-grid">
          <div class="benefit-card">
            <h3>Build Your Personal Presence</h3>
            <p>Contributors may receive a dedicated author profile with bio, image, travel background, social links and published articles.</p>
          </div>

          <div class="benefit-card">
            <h3>Keep Your Name Attached</h3>
            <p>Your contribution will be credited properly. Your name remains attached to your published work.</p>
          </div>

          <div class="benefit-card">
            <h3>Reach More People Over Time</h3>
            <p>We structure and optimize content so useful stories and guides can be discovered through search engines and shared across platforms.</p>
          </div>

          <div class="benefit-card">
            <h3>Social Media Promotion</h3>
            <p>Selected contributions may be promoted through Sulav Yatra's social media channels and short-form content.</p>
          </div>

          <div class="benefit-card highlighted-benefit">
            <h3>Future Paid Opportunities</h3>
            <p>As Sulav Yatra grows, we hope to create paid opportunities for contributors, photographers, videographers and local travel storytellers.</p>
          </div>
        </div>
      </Container>
    </section>

    <section class="submit-section">
      <Container>
        <div class="submit-box">
          <div>
            <span class="section-kicker">How to submit</span>
            <h2>Send us your idea.</h2>
            <p>
              If you are interested in contributing, send us a short introduction about yourself,
              places you have traveled or know well, your article or story idea, and any samples,
              photos, videos or social links you would like to include.
            </p>
          </div>

          <a class="email-button" href="mailto:mail@sulavyatra.com">mail@sulavyatra.com</a>
        </div>
      </Container>
    </section>

    <section class="cta-section">
      <Container>
        <div class="cta-box">
          <span class="section-kicker">Join the journey</span>
          <h2>Let’s Build Nepal’s Most Authentic Travel Platform</h2>
          <p>
            Sulav Yatra is being built slowly, intentionally and with respect for Nepal. If you care
            about real travel experiences, useful information and authentic storytelling, we invite you
            to join the journey.
          </p>
          <strong>Explore Nepal. Share Stories. Keep Discovering.</strong>
        </div>
      </Container>
    </section>
  </main>
</MainLayout>

<style>
  main {
    background: #fffdf8;
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 6.5rem 0 4.5rem;
    text-align: center;
    background:
      radial-gradient(circle at 16% 18%, rgba(0, 113, 186, 0.18), transparent 30%),
      radial-gradient(circle at 84% 20%, rgba(240, 125, 0, 0.14), transparent 32%),
      linear-gradient(180deg, #fffdf8 0%, #f8fafc 100%);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, transparent, black 18%, transparent 95%);
    pointer-events: none;
  }

  .hero-content,
  .section-header {
    position: relative;
    z-index: 1;
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow,
  .section-kicker {
    display: inline-block;
    color: var(--color-secondary);
    font-size: 0.88rem;
    font-weight: 900;
  }

  h1 {
    margin: 1rem 0;
    color: var(--color-primary);
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 1.02;
    letter-spacing: -0.06em;
  }

  h2 {
    margin: 0.85rem 0 1rem;
    color: #102033;
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.045em;
  }

  h3 {
    color: #102033;
  }

  p {
    color: #334155;
    line-height: 1.82;
  }

  .hero p,
  .section-header p {
    max-width: 760px;
    margin: 0 auto;
    color: var(--color-text-light);
    font-size: 1.08rem;
  }

  .intro-section,
  .mission-section,
  .who-section,
  .share-section,
  .rules-section,
  .benefits-section,
  .submit-section,
  .cta-section {
    padding: 4.5rem 0;
  }

  .intro-section,
  .rules-section,
  .submit-section {
    background: white;
  }

  .intro-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: 2rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.4rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 32px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.94));
    box-shadow: 0 24px 80px rgba(15, 23, 42, 0.08);
  }

  .intro-note {
    padding: 2rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at 18% 12%, rgba(240, 125, 0, 0.18), transparent 34%),
      linear-gradient(135deg, var(--color-primary), #005f9c);
    color: white;
    box-shadow: 0 24px 70px rgba(0, 113, 186, 0.22);
  }

  .intro-note strong {
    display: block;
    margin-bottom: 0.8rem;
    font-size: 1.75rem;
    line-height: 1.18;
    letter-spacing: -0.04em;
  }

  .intro-note span {
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.75;
  }

  .mission-box,
  .submit-box,
  .cta-box {
    max-width: 980px;
    margin: 0 auto;
    padding: 3rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 32px;
    background:
      radial-gradient(circle at 18% 16%, rgba(0, 113, 186, 0.1), transparent 32%),
      radial-gradient(circle at 88% 22%, rgba(240, 125, 0, 0.1), transparent 34%),
      linear-gradient(135deg, #ffffff, #f8fafc);
    box-shadow: 0 20px 70px rgba(15, 23, 42, 0.07);
  }

  .people-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    max-width: 980px;
    margin: 2rem auto 0;
  }

  .people-grid span {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(0, 113, 186, 0.16);
    border-radius: 999px;
    background: white;
    color: var(--color-primary);
    font-weight: 800;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.04);
  }

  .content-grid,
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 2.25rem;
  }

  .content-card,
  .benefit-card,
  .rules-list > div {
    padding: 1.65rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16px 48px rgba(15, 23, 42, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .content-card:hover,
  .benefit-card:hover,
  .rules-list > div:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.1);
  }

  .content-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    margin-bottom: 1rem;
    border-radius: 14px;
    background: rgba(0, 113, 186, 0.1);
    color: var(--color-primary);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .content-card h3,
  .benefit-card h3,
  .rules-list h3 {
    margin-bottom: 0.7rem;
  }

  .content-card p,
  .benefit-card p,
  .rules-list p {
    margin: 0;
    color: var(--color-text-light);
  }

  .rules-layout {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.2fr);
    gap: 2rem;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
  }

  .rules-intro {
    position: sticky;
    top: 96px;
  }

  .rules-list {
    display: grid;
    gap: 1rem;
  }

  .highlighted-benefit {
    grid-column: span 2;
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.18), transparent 34%),
      linear-gradient(135deg, var(--color-primary), #005f9c);
  }

  .highlighted-benefit h3,
  .highlighted-benefit p {
    color: white;
  }

  .submit-box {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
  }

  .email-button {
    display: inline-flex;
    padding: 1rem 1.25rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: white;
    font-weight: 900;
    white-space: nowrap;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .email-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(0, 113, 186, 0.18);
  }

  .cta-section {
    padding-bottom: 7rem;
  }

  .cta-box {
    text-align: center;
  }

  .cta-box strong {
    display: block;
    margin-top: 1.25rem;
    color: var(--color-primary);
    font-size: 1.1rem;
  }

  @media (max-width: 980px) {
    .intro-card,
    .rules-layout,
    .submit-box {
      grid-template-columns: 1fr;
    }

    .rules-intro {
      position: static;
    }

    .content-grid,
    .benefits-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .highlighted-benefit {
      grid-column: span 1;
    }
  }

  @media (max-width: 700px) {
    .content-grid,
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .intro-card,
    .mission-box,
    .submit-box,
    .cta-box {
      padding: 1.5rem;
    }

    .hero {
      padding: 4rem 0 3rem;
    }
  }
</style>