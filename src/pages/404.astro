---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Page Not Found"
  description="The page you are looking for could not be found. Search Sulav Yatra or explore our Nepal travel guides."
  canonical="https://sulavyatra.com/404"
>
  <main class="not-found-page">
    <section class="not-found-hero">
      <div class="eyebrow">404 · Page Not Found</div>
      <h1>Lost somewhere on the journey?</h1>
      <p>
        The page you are looking for may have moved, no longer exists, or the link may be incorrect.
        You can search Sulav Yatra or continue exploring our Nepal travel guides below.
      </p>

      <div class="search-actions">
        <form class="search-box" action="/search" method="get">
          <label class="sr-only" for="not-found-search">Search Sulav Yatra</label>
          <input
            id="not-found-search"
            type="search"
            name="q"
            placeholder="Search destinations, guides, activities..."
          />
          <button type="submit">Search</button>
        </form>
        <a class="home-button" href="/">Homepage</a>
      </div>

      <div class="quick-links" aria-label="Popular Sulav Yatra sections">
        <a href="/category/places-to-visit-in-nepal">Places To Go</a>
        <a href="/category/things-to-do-in-nepal">Things To Do</a>
        <a href="/category/nepal-travel-essentials">Travel Essentials</a>
        <a href="/articles">Latest Articles</a>
      </div>

      <a class="home-link" href="/">Back to Homepage</a>
    </section>
  </main>

  <style is:scoped>
    .not-found-page {
      min-height: 70vh;
      padding: 2rem 1rem 4rem;
    }

    .not-found-hero {
      width: min(100%, 1080px);
      margin: 0 auto;
      padding: 5rem 2rem;
      text-align: center;
      background:
        radial-gradient(circle at 15% 18%, rgba(0, 113, 186, 0.14), transparent 32%),
        radial-gradient(circle at 85% 18%, rgba(240, 125, 0, 0.14), transparent 32%),
        linear-gradient(180deg, #fffdf8, #f8fafc);
      border: 1px solid rgba(229, 231, 235, 0.7);
      border-radius: 28px;
    }

    .eyebrow {
      margin-bottom: 1rem;
      color: var(--color-secondary);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    h1 {
      max-width: 900px;
      margin: 0 auto 1.25rem;
      color: var(--color-primary);
      font-size: clamp(2.75rem, 5.5vw, 5.25rem);
      letter-spacing: -0.045em;
    }

    p {
      max-width: 760px;
      margin: 0 auto 2rem;
      color: var(--color-text-light);
      font-size: 1.05rem;
      line-height: 1.85;
    }

    .search-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      width: min(100%, 820px);
      margin: 0 auto 1.5rem;
    }

    .search-box {
      display: flex;
      flex: 1;
      min-width: 0;
      padding: 0.45rem;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
    }

    .search-box input {
      flex: 1;
      min-width: 0;
      padding: 0.95rem 1.1rem;
      border: 0;
      outline: 0;
      color: var(--color-text);
      background: transparent;
    }

    .search-box button,
    .home-button {
      padding: 0.95rem 1.5rem;
      border: 0;
      border-radius: 999px;
      background: var(--color-primary);
      color: white;
      font-weight: 800;
      cursor: pointer;
      transition: var(--transition-fast);
    }

    .search-box button:hover,
    .home-button:hover {
      background: var(--color-secondary);
      transform: translateY(-1px);
    }

    .home-button {
      text-decoration: none;
      white-space: nowrap;
    }

    .quick-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
      margin: 1.5rem auto 2rem;
    }

    .quick-links a {
      padding: 0.7rem 1rem;
      color: var(--color-text);
      font-weight: 700;
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      transition: var(--transition-fast);
    }

    .quick-links a:hover {
      color: var(--color-primary);
      border-color: rgba(0, 113, 186, 0.35);
      transform: translateY(-1px);
    }

    .home-link {
      display: inline-flex;
      color: var(--color-primary);
      font-weight: 800;
    }

    .home-link:hover {
      color: var(--color-secondary);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 700px) {
      .not-found-page {
        padding: 1rem 0.5rem 3rem;
      }

      .not-found-hero {
        padding: 3.25rem 1.25rem 2.75rem;
        border-radius: 22px;
      }

      h1 {
        font-size: clamp(2.35rem, 13vw, 3.4rem);
        letter-spacing: -0.035em;
      }

      p {
        font-size: 1rem;
        line-height: 1.75;
      }

      .search-actions {
        display: grid;
        gap: 0.65rem;
      }

      .search-box {
        display: grid;
        gap: 0.5rem;
        padding: 0.65rem;
        border-radius: 22px;
      }

      .search-box input,
      .search-box button,
      .home-button {
        width: 100%;
        border-radius: 16px;
      }
    }
  </style>
</MainLayout>
