---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/common/Container.astro";
import { WORDPRESS_URL } from "../lib/config";
---

<MainLayout
  title="Search Nepal Travel Guides"
  description="Search Sulav Yatra for Nepal travel guides, destinations, things to do, festivals, culture and practical travel information."
>
  <main>
    <section class="search-hero">
      <Container>
        <div class="search-hero-content">
          <span class="eyebrow">Search Sulav Yatra</span>
          <h1>Find Nepal travel guides, places and stories</h1>
          <p>
            Search destinations, experiences, festivals, culture and practical
            travel information from Sulav Yatra.
          </p>

          <form method="GET" action="/search" class="search-form">
            <input
              type="text"
              name="q"
              placeholder="Search Pokhara, Chitwan, Mustang, festivals..."
              data-search-input
            />

            <button type="submit">
              Search
            </button>
          </form>

          <div class="popular-searches" aria-label="Popular searches">
            <span>Popular:</span>
            <a href="/search?q=Pokhara">Pokhara</a>
            <a href="/search?q=Chitwan">Chitwan</a>
            <a href="/search?q=Mustang">Mustang</a>
            <a href="/search?q=Festivals">Festivals</a>
            <a href="/search?q=Travel%20Essentials">Travel Essentials</a>
          </div>
        </div>
      </Container>
    </section>

    <section class="section search-results-section">
      <Container>
        <div class="results-panel">
          <div class="results-topline">
            <p class="results-count" data-results-count>
              Start by searching for a destination, activity or travel topic.
            </p>

            <a href="/articles" class="browse-link">Browse all articles →</a>
          </div>

          <div class="empty-state" data-empty-state>
            <div class="empty-icon" aria-hidden="true">🧭</div>
            <h2>What are you planning?</h2>
            <p>
              Try searching for a destination like Pokhara, a region like Everest,
              or a topic like permits, festivals or things to do.
            </p>

            <div class="empty-grid">
              <a href="/places-to-visit-in-nepal">Places To Go</a>
              <a href="/things-to-do-in-nepal">Things To Do</a>
              <a href="/nepal-travel-essentials">Travel Essentials</a>
            </div>

            <div class="destination-suggestions" aria-label="Suggested destinations">
              <a href="/search?q=Pokhara">
                <img src="/images/homepage/featured-destinations/Pokhara.avif" alt="Pokhara" loading="lazy" />
                <span>Pokhara</span>
              </a>
              <a href="/search?q=Chitwan">
                <img src="/images/homepage/featured-destinations/chitwan.avif" alt="Chitwan" loading="lazy" />
                <span>Chitwan</span>
              </a>
              <a href="/search?q=Mustang">
                <img src="/images/homepage/featured-destinations/mustang.avif" alt="Mustang" loading="lazy" />
                <span>Mustang</span>
              </a>
            </div>
          </div>

          <div class="results-grid" data-results-grid></div>
        </div>
      </Container>
    </section>
  </main>
</MainLayout>

<style>
  .search-hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 0 4rem;
    text-align: center;
    background:
      radial-gradient(circle at 16% 18%, rgba(0, 113, 186, 0.18), transparent 30%),
      radial-gradient(circle at 84% 20%, rgba(240, 125, 0, 0.15), transparent 32%),
      linear-gradient(180deg, #fffdf8 0%, #f8fafc 100%);
  }

  .search-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, transparent, black 18%, transparent 95%);
    pointer-events: none;
  }

  .search-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-secondary);
    font-weight: 800;
  }

  .search-hero h1 {
    max-width: 900px;
    margin: 0 auto 1.2rem;
    color: var(--color-primary);
    font-size: clamp(2.5rem, 5.4vw, 4.7rem);
    line-height: 1.04;
    letter-spacing: -0.05em;
  }

  .search-hero p {
    max-width: 720px;
    margin: 0 auto 2rem;
    color: var(--color-text-light);
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 760px;
    margin: 0 auto 1.3rem;
    padding: 0.45rem;
    border: 1px solid rgba(0, 113, 186, 0.22);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 80px rgba(0, 113, 186, 0.12), 0 12px 40px rgba(240, 125, 0, 0.08);
    backdrop-filter: blur(16px);
  }

  .search-form input {
    flex: 1 1 auto;
    width: 100%;
    min-width: 0;
    padding: 1.05rem 1.15rem;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-text);
    font-size: 1rem;
  }

  .search-form button {
    border: 0;
    flex-shrink: 0;
    padding: 1.05rem 1.65rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-primary), #005f9c);
    color: white;
    font-weight: 800;
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .search-form button:hover {
    transform: translateY(-1px);
  }

  .popular-searches {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    color: var(--color-text-light);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .popular-searches a {
    padding: 0.5rem 0.8rem;
    border: 1px solid rgba(0, 113, 186, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.74);
    color: var(--color-primary);
    transition: var(--transition-fast);
  }

  .popular-searches a:hover {
    border-color: var(--color-primary);
    color: var(--color-secondary);
  }

  .search-results-section {
    background: white;
  }

  .results-panel {
    min-height: 420px;
  }

  .results-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .results-count {
    color: var(--color-text-light);
    font-weight: 700;
  }

  .browse-link {
    color: var(--color-primary);
    font-weight: 800;
  }

  .empty-state {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 28px;
    background:
      radial-gradient(circle at 20% 12%, rgba(0, 113, 186, 0.08), transparent 34%),
      linear-gradient(180deg, #ffffff, #f8fafc);
    text-align: center;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.05);
  }

  .empty-state.is-hidden {
    display: none;
  }

  .empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin-bottom: 1.25rem;
    border-radius: 22px;
    background: linear-gradient(135deg, rgba(0, 113, 186, 0.12), rgba(240, 125, 0, 0.12));
    font-size: 2rem;
  }

  .empty-state h2 {
    margin-bottom: 0.85rem;
    color: #102033;
    font-size: 1.7rem;
  }

  .empty-state p {
    max-width: 560px;
    margin: 0 auto 1.5rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .empty-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .empty-grid a {
    padding: 0.7rem 1rem;
    border: 1px solid rgba(0, 113, 186, 0.18);
    border-radius: 999px;
    color: var(--color-primary);
    font-weight: 800;
  }

  .destination-suggestions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1.75rem;
  }

  .destination-suggestions a {
    position: relative;
    overflow: hidden;
    min-height: 120px;
    border-radius: 20px;
    color: white;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
  }

  .destination-suggestions img {
    width: 100%;
    height: 100%;
    min-height: 120px;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .destination-suggestions a::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 20%, rgba(15, 23, 42, 0.72));
  }

  .destination-suggestions span {
    position: absolute;
    left: 1rem;
    bottom: 0.85rem;
    z-index: 1;
    font-weight: 900;
  }

  .destination-suggestions a:hover img {
    transform: scale(1.06);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .search-card {
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 24px;
    background: white;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .search-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 26px 70px rgba(15, 23, 42, 0.11);
  }

  .search-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }

  .search-card-content {
    padding: 1.35rem;
  }

  .search-category {
    display: inline-block;
    margin-bottom: 0.65rem;
    color: var(--color-secondary);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .search-card h2 {
    margin-bottom: 0.75rem;
    color: #102033;
    font-size: 1.15rem;
    line-height: 1.35;
  }

  .search-card p {
    margin-bottom: 1.1rem;
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .read-more {
    color: var(--color-primary);
    font-weight: 800;
  }

  .no-results {
    grid-column: 1 / -1;
    padding: 2rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 24px;
    background: #f8fafc;
    text-align: center;
  }

  .no-results strong,
  .no-results span {
    display: block;
  }

  .no-results strong {
    margin-bottom: 0.5rem;
    color: #102033;
    font-size: 1.1rem;
  }

  .no-results span {
    color: var(--color-text-light);
  }

  @media (max-width: 720px) {
    .search-form {
      flex-direction: column;
      align-items: stretch;
      border-radius: 24px;
      padding: 0.75rem;
    }

    .search-form button {
      width: 100%;
    }

    .results-topline {
      align-items: flex-start;
      flex-direction: column;
    }

    .destination-suggestions {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ WORDPRESS_URL }}>
  const input = document.querySelector('[data-search-input]');
  const count = document.querySelector('[data-results-count]');
  const grid = document.querySelector('[data-results-grid]');
  const emptyState = document.querySelector('[data-empty-state]');

  const params = new URLSearchParams(window.location.search);
  const query = params.get('q') || '';

  function stripHtml(html) {
    return html
      .replace(/<[^>]*>/g, '')
      .replace(/&hellip;/g, '...')
      .replace(/&#8230;/g, '...')
      .replace(/&amp;/g, '&')
      .replace(/&nbsp;/g, ' ')
      .replace(/\[\.\.\.\]/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function truncateText(text, length = 120) {
    if (text.length <= length) return text;
    return text.substring(0, length).trim() + '...';
  }

  function getFeaturedImage(post) {
    const media = post._embedded?.['wp:featuredmedia']?.[0];

    return (
      media?.media_details?.sizes?.large?.source_url ||
      media?.media_details?.sizes?.medium_large?.source_url ||
      media?.media_details?.sizes?.medium?.source_url ||
      media?.source_url ||
      ''
    );
  }

  function getAstroUrl(post) {
    return `/${post.slug}`;
  }

  function getPrimaryCategory(post) {
    const terms = post._embedded?.['wp:term']?.[0] || [];
    const primary = terms[0];

    return primary?.name || 'Search Result';
  }

  function renderCard(post) {
    const title = stripHtml(post.title.rendered);
    const excerpt = truncateText(stripHtml(post.excerpt.rendered), 120);
    const image = getFeaturedImage(post);
    const url = getAstroUrl(post);
    const category = getPrimaryCategory(post);

    return `
      <article class="search-card">
        ${
          image
            ? `<a href="${url}"><img src="${image}" alt="${title}" loading="lazy" /></a>`
            : ''
        }

        <div class="search-card-content">
          <span class="search-category">${category}</span>

          <h2>
            <a href="${url}">${title}</a>
          </h2>

          <p>${excerpt}</p>

          <a href="${url}" class="read-more">Read More →</a>
        </div>
      </article>
    `;
  }

  async function runSearch() {
    if (input) {
      input.value = query;
    }

    if (!query) {
      if (count) count.textContent = 'Start by searching for a destination, activity or travel topic.';
      return;
    }

    if (emptyState) {
      emptyState.classList.add('is-hidden');
    }

    if (count) count.textContent = `Searching for "${query}"...`;

    try {
      const response = await fetch(
  `${WORDPRESS_URL}/wp-json/wp/v2/posts?search=${encodeURIComponent(query)}&per_page=12&_embed`,
);

      if (!response.ok) {
        throw new Error('Search request failed');
      }

      const posts = await response.json();

      if (count) {
        count.innerHTML = `${posts.length} result(s) found for <strong>"${query}"</strong>`;
      }

      if (grid) {
        grid.innerHTML = posts.length
          ? posts.map(renderCard).join('')
          : `<div class="no-results"><strong>No results found for "${query}".</strong><span>Try Pokhara, Chitwan, Mustang, festivals or travel essentials.</span></div>`;
      }
    } catch (error) {
      console.error(error);

      if (count) {
        count.textContent = 'Search is temporarily unavailable. Please try again later.';
      }
    }
  }

  runSearch();
</script>