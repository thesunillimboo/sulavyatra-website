

---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/common/Container.astro";
import ArticleCard from "../components/common/ArticleCard.astro";
import {
  getFeaturedImage,
  getPostsByCategorySlug,
  getPrimaryCategory,
  stripHtml,
  truncateText,
} from "../lib/wordpress";

const posts = await getPostsByCategorySlug("things-to-do-in-nepal", 24);
---

<MainLayout
  title="Things To Do In Nepal | Sulav Yatra"
  description="Discover the best things to do in Nepal, from trekking and wildlife safaris to culture, festivals, food, adventure and local experiences."
>
  <main>
    <section class="category-hero">
      <Container>
        <div class="category-hero-content">
          <span class="eyebrow">Experiences</span>
          <h1>Things To Do In Nepal</h1>
          <p>
            Explore Nepal through adventure, culture, nature, festivals, food,
            trekking routes and unforgettable local experiences.
          </p>
        </div>
      </Container>
    </section>

    <section class="section category-section">
      <Container>
        <div class="category-toolbar">
          <p>{posts.length} experience guide(s)</p>
          <a href="/articles">View all articles →</a>
        </div>

        <div class="category-grid">
          {
            posts.map((post) => (
              <ArticleCard
                title={stripHtml(post.title.rendered)}
                category={getPrimaryCategory(post)}
                excerpt={truncateText(stripHtml(post.excerpt.rendered), 130)}
                image={getFeaturedImage(post)}
                href={`/${post.slug}`}
              />
            ))
          }
        </div>
      </Container>
    </section>
  </main>
</MainLayout>

<style>
  .category-hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 0 4rem;
    text-align: center;
    background:
      radial-gradient(circle at 16% 18%, rgba(0, 113, 186, 0.16), transparent 30%),
      radial-gradient(circle at 84% 20%, rgba(240, 125, 0, 0.14), transparent 32%),
      linear-gradient(180deg, #fffdf8 0%, #f8fafc 100%);
  }

  .category-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, transparent, black 18%, transparent 95%);
    pointer-events: none;
  }

  .category-hero-content {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-secondary);
    font-weight: 800;
  }

  .category-hero h1 {
    margin-bottom: 1.2rem;
    color: var(--color-primary);
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
    line-height: 1.04;
    letter-spacing: -0.05em;
  }

  .category-hero p {
    max-width: 720px;
    margin: 0 auto;
    color: var(--color-text-light);
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .category-section {
    background: white;
  }

  .category-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .category-toolbar p {
    color: var(--color-text-light);
    font-weight: 700;
  }

  .category-toolbar a {
    color: var(--color-primary);
    font-weight: 800;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .category-toolbar {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>