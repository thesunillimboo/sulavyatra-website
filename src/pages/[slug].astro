</style>
<script>
  const progressBar = document.querySelector('[data-reading-progress-bar]');
  const mobileProgressBar = document.querySelector('[data-mobile-reading-progress-bar]');
  const progressText = document.querySelector('[data-reading-progress-text]');
  const articleContent = document.querySelector('.article-content');
  const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
  const headings = tocLinks
    .map((link) => {
      const id = link.getAttribute('data-toc-link');
      const heading = id ? document.getElementById(id) : null;
      return heading ? { id, heading, link } : null;
    })
    .filter(Boolean);

  function updateReadingProgress() {
    if (!articleContent) return;

    const rect = articleContent.getBoundingClientRect();
    const articleTop = window.scrollY + rect.top;
    const articleHeight = articleContent.scrollHeight - window.innerHeight;
    const progress = articleHeight > 0
      ? Math.min(100, Math.max(0, ((window.scrollY - articleTop) / articleHeight) * 100))
      : 0;

    if (progressBar) {
      progressBar.style.width = `${progress}%`;
    }

    if (mobileProgressBar) {
      mobileProgressBar.style.width = `${progress}%`;
    }

    if (progressText) {
      progressText.textContent = `${Math.round(progress)}% complete`;
    }
  }

  function updateActiveTocLink() {
    if (!headings.length) return;

    let activeItem = headings[0];

    for (const item of headings) {
      const top = item.heading.getBoundingClientRect().top;

      if (top <= 130) {
        activeItem = item;
      }
    }

    tocLinks.forEach((link) => link.classList.remove('is-active'));
    activeItem.link.classList.add('is-active');
  }

  function updateArticleSidebar() {
    updateReadingProgress();
    updateActiveTocLink();
  }

  updateArticleSidebar();
  window.addEventListener('scroll', updateArticleSidebar, { passive: true });
  window.addEventListener('resize', updateArticleSidebar);
</script>