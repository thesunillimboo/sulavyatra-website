---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/common/Container.astro";

const canonicalUrl = "https://sulavyatra.com/partner";

const partnerPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Become a Travel Partner | Sulav Yatra",
  description:
    "Partner with Sulav Yatra and help travelers discover authentic experiences, accommodation, activities and tourism services across Nepal.",
  url: canonicalUrl,
  publisher: {
    "@type": "Organization",
    name: "Sulav Yatra",
    url: "https://sulavyatra.com",
  },
};
---

<MainLayout
  title="Become a Travel Partner"
  description="Partner with Sulav Yatra and help travelers discover authentic experiences, accommodation, activities and tourism services across Nepal."
  canonical={canonicalUrl}
  image="/images/branding/sulav-yatra-social-share.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(partnerPageSchema)} />

  <main>
    <section class="hero">
      <Container>
        <div class="hero-content">
          <span class="eyebrow">Become a Travel Partner</span>
          <h1>Let’s Help More People Discover Nepal</h1>
          <p>
            Join Sulav Yatra as we build a trusted travel platform connecting travelers with
            authentic experiences, reliable tourism businesses and local hospitality across Nepal.
          </p>
          <p class="hero-subtext">
            We are not just looking for sponsors. We are looking for hotels, homestays, guides,
            agencies, activity providers and local businesses who can help travelers experience Nepal better.
          </p>
        </div>
      </Container>
    </section>

    <section class="intro-section">
      <Container>
        <div class="intro-card">
          <div class="intro-copy">
            <span class="section-kicker">Why we are building this</span>
            <h2>Travel is better when good people are easier to find.</h2>
            <p>
              Sulav Yatra began as a travel content platform. Today, our vision is bigger.
            </p>
            <p>
              We want to connect travelers with reliable tourism businesses, local experiences and
              authentic hospitality across Nepal.
            </p>
            <p>
              Our goal is simple: help travelers discover Nepal with confidence while helping quality
              tourism businesses become more visible.
            </p>
            <p>
              Many good tourism businesses in Nepal still depend on word of mouth, social media posts or
              scattered listings. At the same time, travelers often struggle to know which services are
              reliable, local and genuinely useful. Sulav Yatra aims to slowly bridge that gap through
              content, discovery and trust.
            </p>
          </div>

          <aside class="highlight-box">
            <strong>Building Nepal’s travel ecosystem.</strong>
            <span>One destination, one story and one trusted partner at a time.</span>
          </aside>
        </div>
      </Container>
    </section>

    <section class="partners-section section-soft">
      <Container>
        <div class="section-header">
          <span class="section-kicker">Who can become a partner?</span>
          <h2>Tourism businesses and service providers across Nepal.</h2>
        </div>

        <div class="partner-grid">
          <span>Hotels & Resorts</span>
          <span>Homestays</span>
          <span>Trekking Companies</span>
          <span>Tour Operators</span>
          <span>Travel Agencies</span>
          <span>Adventure Activities</span>
          <span>Local Guides</span>
          <span>Transportation Services</span>
          <span>Restaurants & Cafés</span>
          <span>Travel Gear Brands</span>
          <span>Tourism Startups</span>
          <span>Tourism Organizations</span>
        </div>

        <div class="section-copy">
          <p>
            This page is for businesses and individuals who are directly or indirectly part of Nepal’s
            travel experience. You may be running a family homestay, managing a city hotel, organizing
            treks, offering jeep rides, guiding travelers through cultural sites, or building a local tourism startup.
          </p>
          <p>
            If your work helps travelers explore Nepal in a better, safer or more meaningful way, there
            may be a place for you in the Sulav Yatra ecosystem.
          </p>
        </div>
      </Container>
    </section>

    <section class="opportunities-section">
      <Container>
        <div class="section-header">
          <span class="section-kicker">Partnership opportunities</span>
          <h2>Flexible ways to work together.</h2>
        </div>

        <div class="section-copy">
          <p>
            Partnership does not have to look the same for everyone. Some partners may want simple visibility,
            while others may want featured content, campaign support, destination exposure or future listing opportunities.
          </p>
          <p>
            We are keeping the model flexible because Sulav Yatra itself is still growing. The goal is to
            create partnerships that feel useful for travelers and fair for the businesses involved.
          </p>
        </div>

        <div class="cards-grid">
          <div class="card">
            <h3>Partner Visibility</h3>
            <p>
              Help travelers discover your business through Sulav Yatra’s future destination, guide and partner resources.
            </p>
          </div>

          <div class="card">
            <h3>Destination Features</h3>
            <p>
              Relevant businesses may be included where they naturally support a destination or travel guide.
            </p>
          </div>

          <div class="card">
            <h3>Activities & Experiences</h3>
            <p>
              Showcase tours, adventures, cultural experiences, local activities and meaningful things to do.
            </p>
          </div>

          <div class="card">
            <h3>Accommodation Features</h3>
            <p>
              Help travelers discover hotels, resorts, homestays and unique places to stay across Nepal.
            </p>
          </div>

          <div class="card featured-card">
            <h3>Promotional & Featured Placements</h3>
            <p>
              Paid promotional visibility, sponsored content, featured placements and future advertising opportunities.
            </p>
          </div>

          <div class="card">
            <h3>Custom Partnerships</h3>
            <p>
              Have a different idea? We are open to meaningful collaborations that fit travelers and local tourism.
            </p>
          </div>
        </div>
      </Container>
    </section>

    <section class="approach-section section-soft">
      <Container>
        <div class="approach-box content-box">
          <span class="section-kicker">Our approach</span>
          <h2>Trust before promotion.</h2>
          <p>
            We are not building a platform filled with advertisements.
          </p>
          <p>
            We want recommendations that genuinely help travelers. That means quality over quantity,
            honest representation, useful information and long-term partnerships.
          </p>
          <p>
            Promotional and featured opportunities will remain open, but they should never damage reader trust.
            If a business is promoted on Sulav Yatra, it should still be relevant, clearly presented and useful
            to the people planning their Nepal journey.
          </p>
        </div>
      </Container>
    </section>

    <section class="future-section">
      <Container>
        <div class="future-box content-box">
          <span class="section-kicker">Looking ahead</span>
          <h2>We are building carefully.</h2>
          <p>
            Sulav Yatra is still growing. Our long-term goal is to become one of Nepal’s most trusted travel
            platforms, connecting travelers with authentic experiences and responsible tourism businesses across the country.
          </p>
          <p>
            In the beginning, this may simply mean better content, honest recommendations and stronger visibility
            for local businesses. Over time, it may grow into a wider travel network where destinations, services,
            guides, stays and experiences are easier to discover in one place.
          </p>
        </div>
      </Container>
    </section>

    <section class="cta-section">
      <Container>
        <div class="cta-box">
          <span class="section-kicker">Become a Travel Partner</span>
          <h2>Interested in working with Sulav Yatra?</h2>
          <p>
            Send us your business name, location, website or social media links, type of service and a short introduction.
            You can also tell us what kind of partnership you are interested in — visibility, featured content,
            promotional placement, destination collaboration or something custom.
          </p>
          <a href="mailto:mail@sulavyatra.com" class="email-btn">mail@sulavyatra.com</a>
        </div>
      </Container>
    </section>
  </main>
</MainLayout>

<style>
  main {
    background: #fffdf8;
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 6.5rem 0 4.75rem;
    text-align: center;
    background:
      radial-gradient(circle at 16% 18%, rgba(0, 113, 186, 0.18), transparent 30%),
      radial-gradient(circle at 84% 20%, rgba(240, 125, 0, 0.14), transparent 32%),
      linear-gradient(180deg, #fffdf8 0%, #f8fafc 100%);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, transparent, black 18%, transparent 95%);
    pointer-events: none;
  }

  .hero-content,
  .section-header {
    position: relative;
    z-index: 1;
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow,
  .section-kicker {
    display: inline-block;
    color: var(--color-secondary);
    font-size: 0.88rem;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  h1 {
    max-width: 900px;
    margin: 1rem auto 1.35rem;
    color: var(--color-primary);
    font-size: clamp(3rem, 6vw, 5.2rem);
    line-height: 1.03;
    letter-spacing: -0.055em;
  }

  h2 {
    margin: 0.85rem 0 1.25rem;
    color: #102033;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.13;
    letter-spacing: -0.045em;
  }

  h3 {
    margin-bottom: 0.75rem;
    color: #102033;
    line-height: 1.25;
  }

  p {
    color: #334155;
    line-height: 1.86;
  }

  .hero p,
  .section-header p {
    max-width: 760px;
    margin: 0 auto;
    color: var(--color-text-light);
    font-size: 1.06rem;
    line-height: 1.78;
  }

  .hero-subtext {
    margin-top: 1rem !important;
    color: #334155 !important;
  }

  .intro-section,
  .partners-section,
  .opportunities-section,
  .approach-section,
  .future-section,
  .cta-section {
    padding: 5rem 0;
  }

  .section-soft {
    background: rgba(255, 255, 255, 0.72);
  }

  .intro-card,
  .content-box,
  .cta-box {
    max-width: 1060px;
    margin: 0 auto;
    padding: 3rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 80px rgba(15, 23, 42, 0.08);
  }

  .intro-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 340px);
    gap: 2.4rem;
    align-items: stretch;
  }

  .intro-copy p + p,
  .content-box p + p,
  .section-copy p + p,
  .cta-box p + p {
    margin-top: 1rem;
  }

  .highlight-box {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
    border-radius: 26px;
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.16), transparent 34%),
      linear-gradient(135deg, var(--color-primary), #005f9c);
    color: white;
    box-shadow: 0 24px 70px rgba(0, 113, 186, 0.22);
  }

  .highlight-box strong {
    display: block;
    margin-bottom: 0.85rem;
    color: white;
    font-size: 1.65rem;
    line-height: 1.18;
    letter-spacing: -0.04em;
  }

  .highlight-box span {
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.75;
  }

  .section-copy {
    max-width: 850px;
    margin: 2.25rem auto 0;
    text-align: center;
  }

  .section-copy p {
    color: #334155;
    line-height: 1.9;
  }

  .partner-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
    max-width: 980px;
    margin: 2.2rem auto 0;
  }

  .partner-grid span {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(0, 113, 186, 0.16);
    border-radius: 999px;
    background: white;
    color: var(--color-primary);
    font-size: 0.92rem;
    font-weight: 850;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.04);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .card {
    padding: 1.75rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 16px 48px rgba(15, 23, 42, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.1);
  }

  .card p {
    margin: 0;
    color: var(--color-text-light);
    font-size: 0.96rem;
    line-height: 1.72;
  }

  .featured-card {
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.16), transparent 34%),
      linear-gradient(135deg, var(--color-primary), #005f9c);
  }

  .featured-card h3,
  .featured-card p {
    color: white;
  }

  .approach-section,
  .future-section {
    padding-top: 5.5rem;
    padding-bottom: 5.5rem;
  }

  .cta-section {
    padding-bottom: 7rem;
  }

  .cta-box {
    max-width: 980px;
    text-align: center;
    background:
      radial-gradient(circle at 18% 16%, rgba(0, 113, 186, 0.12), transparent 32%),
      radial-gradient(circle at 88% 22%, rgba(240, 125, 0, 0.12), transparent 34%),
      linear-gradient(135deg, #ffffff, #f8fafc);
  }

  .cta-box p {
    max-width: 760px;
    margin-right: auto;
    margin-left: auto;
  }

  .email-btn {
    display: inline-flex;
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: white;
    font-weight: 900;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .email-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(0, 113, 186, 0.18);
  }

  @media (max-width: 980px) {
    .intro-card,
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .hero {
      padding: 4rem 0 3rem;
    }

    .intro-section,
    .partners-section,
    .opportunities-section,
    .approach-section,
    .future-section,
    .cta-section {
      padding: 3.5rem 0;
    }

    .intro-card,
    .content-box,
    .cta-box {
      padding: 1.5rem;
    }
  }
</style>