---
import Container from "../common/Container.astro";

const exploreItems = [
  {
    icon: "🏔️",
    title: "Places To Go",
    description:
      "Discover cities, villages, mountains, lakes and hidden gems across Nepal.",
    href: "/places-to-visit-in-nepal",
    linkText: "Explore Destinations",
  },
  {
    icon: "🎒",
    title: "Things To Do",
    description:
      "Find adventures, cultural experiences, trekking routes, festivals and activities.",
    href: "/things-to-do-in-nepal",
    linkText: "Explore Activities",
  },
  {
    icon: "🧭",
    title: "Travel Essentials",
    description:
      "Plan better with transport tips, permits, costs, safety advice and practical guidance.",
    href: "/nepal-travel-essentials",
    linkText: "Plan Your Trip",
  },
];
---

<section class="section explore-nepal">
  <Container>
    <div class="section-header">
      <span class="eyebrow">Start Exploring</span>
      <h2>Explore Nepal</h2>
      <p>
        Start your journey by discovering destinations, experiences and practical
        travel guidance designed for real Nepal travellers.
      </p>
    </div>

    <div class="explore-grid">
      {
        exploreItems.map((item) => (
          <article class="explore-card">
            <div class="icon-wrap" aria-hidden="true">
              <span>{item.icon}</span>
            </div>

            <h3>{item.title}</h3>
            <p>{item.description}</p>

            <a href={item.href}>
              {item.linkText} →
            </a>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .explore-nepal {
    position: relative;
    background: white;
  }

  .section-header {
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 0.75rem;
    color: var(--color-secondary);
    font-weight: 800;
  }

  .section-header h2 {
    margin-bottom: 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.04em;
  }

  .section-header p {
    color: var(--color-text-light);
    font-size: 1.05rem;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .explore-card {
    position: relative;
    overflow: hidden;
    padding: 2rem;
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.92)),
      radial-gradient(circle at 20% 12%, rgba(0, 113, 186, 0.1), transparent 34%);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .explore-card::after {
    content: "";
    position: absolute;
    right: -4rem;
    bottom: -4rem;
    width: 11rem;
    height: 11rem;
    border-radius: 999px;
    background: rgba(240, 125, 0, 0.1);
  }

  .explore-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 113, 186, 0.3);
    box-shadow: 0 26px 70px rgba(15, 23, 42, 0.1);
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    margin-bottom: 1.5rem;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(0, 113, 186, 0.12), rgba(240, 125, 0, 0.12));
    font-size: 1.7rem;
  }

  .explore-card h3 {
    margin-bottom: 0.85rem;
    font-size: 1.35rem;
  }

  .explore-card p {
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
  }

  .explore-card a {
    position: relative;
    z-index: 1;
    color: var(--color-primary);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .explore-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
