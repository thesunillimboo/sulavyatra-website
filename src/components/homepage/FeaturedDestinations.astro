---
import Container from "../common/Container.astro";

const destinations = [
  {
    title: "Pokhara",
    description: "Lakes, mountain views, adventure sports and relaxed city life.",
    image: "/images/homepage/featured-destinations/Pokhara.avif",
    href: "/search?q=Pokhara",
  },
  {
    title: "Everest Region",
    description: "Sherpa culture, Himalayan scenery and iconic trekking routes.",
    image: "/images/homepage/featured-destinations/everest-region.avif",
    href: "/search?q=Everest",
  },
  {
    title: "Mustang",
    description: "Ancient Himalayan kingdom, dramatic landscapes and culture.",
    image: "/images/homepage/featured-destinations/mustang.avif",
    href: "/search?q=Mustang",
  },
  {
    title: "Chitwan",
    description: "Wildlife safaris, jungles and rich Tharu heritage.",
    image: "/images/homepage/featured-destinations/chitwan.avif",
    href: "/search?q=Chitwan",
  },
  {
    title: "Lumbini",
    description: "Birthplace of Buddha and one of Nepal's most important sites.",
    image: "/images/homepage/featured-destinations/Lumbini.avif",
    href: "/search?q=Lumbini",
  },
  {
    title: "Ilam",
    description: "Tea gardens, rolling hills and peaceful eastern landscapes.",
    image: "/images/homepage/featured-destinations/Ilam.avif",
    href: "/search?q=Ilam",
  },
];
---

<section class="section featured-destinations">
  <Container>
    <div class="section-header">
      <span class="eyebrow">Travel Inspiration</span>
      <h2>Featured Destinations</h2>
      <p>
        Discover some of Nepal's most loved destinations and start planning your next journey.
      </p>
    </div>

    <div class="destinations-grid">
      {destinations.map((destination) => (
        <a class="destination-card" href={destination.href}>
          <div class="destination-image">
            <img src={destination.image} alt={destination.title} loading="lazy" />
          </div>

          <div class="destination-content">
            <h3>{destination.title}</h3>
            <p>{destination.description}</p>
            <span>Explore destination →</span>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>

<style>
  .section-header {
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 0.75rem;
    color: var(--color-secondary);
    font-weight: 800;
  }

  .section-header h2 {
    margin-bottom: 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.04em;
  }

  .section-header p {
    color: var(--color-text-light);
  }

  .destinations-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .destination-card {
    overflow: hidden;
    border-radius: 24px;
    background: white;
    border: 1px solid rgba(148, 163, 184, 0.2);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
    transition: all 0.25s ease;
  }

  .destination-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 26px 70px rgba(15, 23, 42, 0.12);
  }

  .destination-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .destination-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .destination-card:hover img {
    transform: scale(1.05);
  }

  .destination-content {
    padding: 1.4rem;
  }

  .destination-content h3 {
    margin-bottom: 0.75rem;
  }

  .destination-content p {
    margin-bottom: 1rem;
    color: var(--color-text-light);
  }

  .destination-content span {
    color: var(--color-primary);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .destinations-grid {
      grid-template-columns: 1fr;
    }
  }
</style>