---
import Container from "../common/Container.astro";
---

<section class="section join-section">
  <Container>
    <div class="section-header">
      <span class="eyebrow">Join The Journey</span>
      <h2>Help Shape Nepal’s Travel Future</h2>
      <p>
        Sulav Yatra is building more than a travel website. We are building a
        growing network of contributors, local storytellers and trusted travel
        partners across Nepal.
      </p>
    </div>

    <div class="join-grid">
      <article class="join-card">
        <span class="card-label">For creators & storytellers</span>
        <h3>Become a Contributor</h3>
        <p>
          Share your Nepal travel stories, photos, videos and local insights to
          help travelers discover Nepal through real experiences.
        </p>
        <a href="/contribute">Share Your Story →</a>
      </article>

      <article class="join-card partner-card">
        <span class="card-label">For travel businesses</span>
        <h3>Become a Travel Partner</h3>
        <p>
          Connect with travelers through trusted recommendations, destination
          guides, local experiences and meaningful partnership opportunities.
        </p>
        <a href="/travel-partners">Explore Partnerships →</a>
      </article>
    </div>
  </Container>
</section>

<style>
  .join-section {
    background: var(--color-primary);
    color: white;
  }

  .section-header {
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 700;
  }

  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .section-header p {
    color: rgba(255, 255, 255, 0.82);
  }

  .join-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .join-card {
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: white;
    color: var(--color-text);
  }

  .card-label {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-secondary);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .join-card h3 {
    margin-bottom: 1rem;
  }

  .join-card p {
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
  }

  .join-card a {
    color: var(--color-primary);
    font-weight: 700;
  }
</style>