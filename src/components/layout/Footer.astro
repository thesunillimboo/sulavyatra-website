---
import Container from "../common/Container.astro";
---

<footer class="footer">
  <Container>
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Sulav Yatra</a>
        <p>
          Discover Nepal through trusted travel guides, local insights,
          cultural stories, and practical travel information.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-column">
          <h3>Explore</h3>
          <ul>
            <li><a href="/category/places-to-visit-in-nepal">Places To Go</a></li>
            <li><a href="/category/things-to-do-in-nepal">Things To Do</a></li>
            <li><a href="/category/nepal-travel-essentials">Travel Essentials</a></li>
            <li><a href="articles">What’s New</a></li>
          </ul>
        </div>

        <div class="footer-column">
          <h3>Join Us</h3>
          <ul>
            <li><a href="/contribute">Become a Contributor</a></li>
            <li><a href="/partner">Become a Travel Partner</a></li>
            <li><a href="/why-sulav-yatra-exists">Why Sulav Yatra Exists</a></li>
            <li><a href="mailto:mail@sulavyatra.com">Contact Us</a></li>
          </ul>
        </div>

        <div class="footer-column">
          <h3>Legal</h3>
          <ul>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/terms-and-conditions">Terms & Conditions</a></li>
            <li><a href="/disclaimer">Disclaimer</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} <strong>Sulav Yatra</strong> Pvt. Ltd. All rights reserved.</p>
      <p>
        Built by
        <a
          href="https://nepalifx.com"
          target="_blank"
          rel="noopener noreferrer"
          class="nepalifx-link"
        >
          <strong>Nepali<span class="fx">Fx</span></strong>
        </a>
      </p>
    </div>
  </Container>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 2rem;
    background: var(--color-surface);
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 2fr);
    gap: 4rem;
    padding-bottom: 3rem;
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-primary);
    font-size: 1.4rem;
    font-weight: 800;
  }

  .footer-brand p {
    max-width: 460px;
    color: var(--color-text-light);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .footer-column h3 {
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .footer-column ul {
    display: grid;
    gap: 0.7rem;
  }

  .footer-column a {
    color: var(--color-text-light);
    font-size: 0.95rem;
    transition: var(--transition-fast);
  }

  .footer-column a:hover {
    color: var(--color-primary);
  }

  .nepalifx-link {
    color: inherit;
    text-decoration: none;
  }

  .fx {
    color: #e53935;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 700px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>