---
interface Props {
  title: string;
  category: string;
  href?: string;
  excerpt?: string;
  image?: string;
}

const {
  title,
  category,
  href = "#",
  excerpt,
  image,
} = Astro.props;
---

<article class="article-card">
  {
    image && (
      <a href={href} class="article-image">
        <img src={image} alt={title} loading="lazy" />
      </a>
    )
  }

  <div class="article-content">
    <span class="article-category">
      {category}
    </span>

    <h3>
      <a href={href}>
        {title}
      </a>
    </h3>

    {
      excerpt && (
        <p>{excerpt}</p>
      )
    }

    <a href={href} class="read-more">
      Read More →
    </a>
  </div>
</article>

<style>
  .article-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    overflow: hidden;
    height: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .article-image {
    display: block;
    margin: 0;
  }

  .article-image img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .article-content {
    padding: 1.5rem;
  }

  .article-category {
    display: inline-block;
    margin-bottom: 0.75rem;
    color: var(--color-secondary);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .article-card h3 {
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .article-card p {
    margin-bottom: 1.25rem;
    color: var(--color-text-light);
  }

  .read-more {
    color: var(--color-primary);
    font-weight: 600;
  }
</style>